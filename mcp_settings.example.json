{
  "mcpServers": {
    "varinth": {
      "command": "python",
      "args": ["-m", "app.mcp_server"],
      "cwd": "REPLACE_WITH_ABSOLUTE_PATH_TO/varinth/backend",
      "env": {
        "SUPABASE_URL": "REPLACE_WITH_YOUR_SUPABASE_URL",
        "SUPABASE_ANON_KEY": "REPLACE_WITH_YOUR_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY": "REPLACE_WITH_YOUR_SERVICE_ROLE_KEY",
        "NVIDIA_API_KEY": "REPLACE_WITH_YOUR_NVIDIA_API_KEY",
        "NVIDIA_API_BASE_URL": "https://integrate.api.nvidia.com/v1",
        "NVIDIA_EMBED_MODEL": "nvidia/nv-embedqa-e5-v5",
        "NVIDIA_CHAT_MODEL": "meta/llama-3.3-70b-instruct",
        "ALLOWED_ORIGINS": "http://localhost:3000",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
